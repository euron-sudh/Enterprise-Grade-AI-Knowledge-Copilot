#!/bin/bash
# ============================================================================
# Pre-push hook — runs local quality checks before pushing to GitHub.
#
# Mirrors the CI pipelines (ci-backend.yml + ci-frontend.yml) so failures
# are caught locally before wasting CI minutes.
#
# To bypass in emergencies:  git push --no-verify
# ============================================================================

set -euo pipefail

# ── Colours (only when stdout is a terminal) ────────────────────────────────
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' CYAN='' BOLD='' DIM='' RESET=''
fi

# ── Helpers ─────────────────────────────────────────────────────────────────
REPO_ROOT="$(git rev-parse --show-toplevel)"
PASS_COUNT=0
FAIL_COUNT=0
TOTAL_START=$(date +%s)

step_pass() {
    PASS_COUNT=$((PASS_COUNT + 1))
    local elapsed=$1
    echo -e "  ${GREEN}✔ PASSED${RESET} ${DIM}(${elapsed}s)${RESET}"
}

step_fail() {
    FAIL_COUNT=$((FAIL_COUNT + 1))
    local elapsed=$1
    echo -e "  ${RED}✘ FAILED${RESET} ${DIM}(${elapsed}s)${RESET}"
}

run_step() {
    local label="$1"
    shift
    echo -e "\n${CYAN}▸ ${label}${RESET}"
    local start=$(date +%s)
    if "$@" > /tmp/pre-push-step-output.log 2>&1; then
        local end=$(date +%s)
        step_pass $((end - start))
    else
        local end=$(date +%s)
        step_fail $((end - start))
        echo -e "${DIM}── Output ──${RESET}"
        cat /tmp/pre-push-step-output.log
        echo -e "${DIM}────────────${RESET}"
    fi
}

# ── Banner ──────────────────────────────────────────────────────────────────
echo -e "\n${BOLD}╔══════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}║   🔍  Pre-Push Quality Checks            ║${RESET}"
echo -e "${BOLD}╚══════════════════════════════════════════╝${RESET}"

# ── Check tool availability ─────────────────────────────────────────────────
SKIP_BACKEND=false
SKIP_FRONTEND=false

if ! command -v python &> /dev/null && ! command -v python3 &> /dev/null; then
    echo -e "${YELLOW}⚠  Python not found — skipping backend checks${RESET}"
    SKIP_BACKEND=true
fi

if ! command -v node &> /dev/null; then
    echo -e "${YELLOW}⚠  Node.js not found — skipping frontend checks${RESET}"
    SKIP_FRONTEND=true
fi

# Determine python command
if command -v python3 &> /dev/null; then
    PYTHON=python3
else
    PYTHON=python
fi

# ════════════════════════════════════════════════════════════════════════════
# BACKEND CHECKS
# ════════════════════════════════════════════════════════════════════════════
if [ "$SKIP_BACKEND" = false ]; then
    echo -e "\n${BOLD}── Backend ───────────────────────────────${RESET}"

    # Activate venv if it exists
    VENV_ACTIVATE=""
    if [ -f "$REPO_ROOT/.venv/Scripts/activate" ]; then
        VENV_ACTIVATE="$REPO_ROOT/.venv/Scripts/activate"
    elif [ -f "$REPO_ROOT/.venv/bin/activate" ]; then
        VENV_ACTIVATE="$REPO_ROOT/.venv/bin/activate"
    elif [ -f "$REPO_ROOT/backend/.venv/Scripts/activate" ]; then
        VENV_ACTIVATE="$REPO_ROOT/backend/.venv/Scripts/activate"
    elif [ -f "$REPO_ROOT/backend/.venv/bin/activate" ]; then
        VENV_ACTIVATE="$REPO_ROOT/backend/.venv/bin/activate"
    fi

    if [ -n "$VENV_ACTIVATE" ]; then
        echo -e "  ${DIM}Using venv: ${VENV_ACTIVATE}${RESET}"
        source "$VENV_ACTIVATE"
    fi

    # Step 1: Backend Lint (flake8)
    if command -v flake8 &> /dev/null; then
        run_step "Backend Lint (flake8)" \
            flake8 "$REPO_ROOT/backend/app" "$REPO_ROOT/backend/tests" \
                --max-line-length=120 \
                --extend-ignore=E501,W503,E302,E303,E305,E402,E127,E128,E221,E712,F401,F841,F541,E401,E741 \
                --count
    else
        echo -e "\n${YELLOW}⚠  flake8 not installed — skipping backend lint${RESET}"
        echo -e "  ${DIM}Install with: pip install flake8${RESET}"
    fi

    # Step 2: Backend Tests (pytest)
    # Note: Only runs currently-passing test modules for fast local gating.
    # The full suite (including WIP modules) runs in GitHub Actions CI.
    # Add new test files here as they are fixed/created.
    if command -v pytest &> /dev/null; then
        run_step "Backend Tests (pytest)" \
            pytest \
                "$REPO_ROOT/backend/tests/test_auth.py" \
                "$REPO_ROOT/backend/tests/test_admin.py" \
                "$REPO_ROOT/backend/tests/test_conversations.py" \
                "$REPO_ROOT/backend/tests/test_knowledge.py" \
                -x --maxfail=3 -q --tb=short --no-header
    else
        echo -e "\n${YELLOW}⚠  pytest not installed — skipping backend tests${RESET}"
        echo -e "  ${DIM}Install with: pip install -r backend/requirements.txt${RESET}"
    fi
fi

# ════════════════════════════════════════════════════════════════════════════
# FRONTEND CHECKS
# ════════════════════════════════════════════════════════════════════════════
if [ "$SKIP_FRONTEND" = false ]; then
    echo -e "\n${BOLD}── Frontend ──────────────────────────────${RESET}"

    # Check node_modules exist
    if [ ! -d "$REPO_ROOT/frontend/node_modules" ]; then
        echo -e "${YELLOW}⚠  frontend/node_modules missing — run 'cd frontend && npm install'${RESET}"
        SKIP_FRONTEND=true
    fi
fi

if [ "$SKIP_FRONTEND" = false ]; then
    # Run frontend commands from inside the frontend directory
    pushd "$REPO_ROOT/frontend" > /dev/null

    # Step 3: Frontend Lint (ESLint / Next.js)
    run_step "Frontend Lint (ESLint)" npm run lint

    # Step 4: Frontend Typecheck (TypeScript)
    run_step "Frontend Typecheck (tsc)" npm run typecheck

    # Step 5: Frontend Unit Tests (Vitest)
    run_step "Frontend Unit Tests (vitest)" npm run test

    popd > /dev/null
fi

# ── Summary ─────────────────────────────────────────────────────────────────
TOTAL_END=$(date +%s)
TOTAL_ELAPSED=$((TOTAL_END - TOTAL_START))

echo -e "\n${BOLD}──────────────────────────────────────────${RESET}"
echo -e "  ${GREEN}✔ Passed: ${PASS_COUNT}${RESET}    ${RED}✘ Failed: ${FAIL_COUNT}${RESET}    ${DIM}⏱  ${TOTAL_ELAPSED}s${RESET}"

if [ "$FAIL_COUNT" -gt 0 ]; then
    echo -e "\n${RED}${BOLD}Push blocked — fix the failures above.${RESET}"
    echo -e "${DIM}To bypass: git push --no-verify${RESET}\n"
    exit 1
fi

echo -e "${GREEN}${BOLD}All checks passed — pushing!${RESET}\n"
exit 0
