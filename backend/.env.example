# ============================================================
# KnowledgeForge Backend — Environment Variables
# Copy this file to .env and fill in the values.
# In production all values marked [SECRET] are stored in
# AWS Secrets Manager and injected by ECS at runtime.
# ============================================================

# ── Database ──────────────────────────────────────────────────
# [SECRET] Full async connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledgeforge
DATABASE_SSL=false

# ── Redis ─────────────────────────────────────────────────────
# [SECRET] Include auth token for production: redis://:TOKEN@host:6379/0
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────
# [SECRET] Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-hex-32

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI APIs ───────────────────────────────────────────────────
# [SECRET] Primary LLM — falls back to OpenAI if not set
ANTHROPIC_API_KEY=sk-ant-...

# [SECRET] Fallback LLM — falls back to mock mode if not set
OPENAI_API_KEY=sk-...

# ── Vector Search (Pinecone) ─────────────────────────────────
# [SECRET] Required for large-scale semantic search
PINECONE_API_KEY=
PINECONE_INDEX_NAME=knowledgeforge
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_EMBEDDING_MODEL=text-embedding-3-small
PINECONE_EMBEDDING_DIMENSION=1536

# [SECRET] Tavily web search (optional)
TAVILY_API_KEY=

# ── Stripe Billing ────────────────────────────────────────────
# [SECRET] Live key starts with sk_live_, test with sk_test_
STRIPE_SECRET_KEY=sk_test_...

# [SECRET] From Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (from Stripe Dashboard → Products)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── Connector OAuth ───────────────────────────────────────────
# GitHub OAuth App (github.com → Settings → Developer settings → OAuth Apps)
GITHUB_CLIENT_ID=
# [SECRET]
GITHUB_CLIENT_SECRET=

# Slack App (api.slack.com/apps → OAuth & Permissions)
SLACK_CLIENT_ID=
# [SECRET]
SLACK_CLIENT_SECRET=

# Notion Integration (notion.so/my-integrations)
NOTION_CLIENT_ID=
# [SECRET]
NOTION_CLIENT_SECRET=

# Base URL for OAuth redirect callbacks
CONNECTOR_OAUTH_REDIRECT_BASE=http://localhost:3000

# ── AWS S3 (optional — falls back to local disk if not set) ──
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
# [SECRET] Leave empty in production to use ECS task IAM role instead
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# ── CORS ──────────────────────────────────────────────────────
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000"]
# Single production frontend URL (merged with CORS_ORIGINS at runtime)
# FRONTEND_URL=https://app.knowledgeforge.ai

# ── App ───────────────────────────────────────────────────────
APP_VERSION=1.0.0
DEBUG=false
