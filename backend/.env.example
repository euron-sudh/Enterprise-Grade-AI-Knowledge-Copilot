# Database (Supabase cloud — postgresql+asyncpg connection string)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledgeforge

# Redis
REDIS_URL=redis://localhost:6379

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-hex-32

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI APIs (optional - falls back to mock if not set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Tavily web search (optional - enables real-time web search in chat)
# Get your key at https://app.tavily.com
TAVILY_API_KEY=

# ── Supabase pgvector (Semantic Search) ─────────────────────────────────────
# The OPENAI_API_KEY above is also used to generate embeddings for semantic search.
# Embeddings use text-embedding-3-small (1536 dimensions, ~$0.00002 per 1K tokens).
# If OPENAI_API_KEY is not set, the app falls back to keyword (ILIKE) search.
#
# ONE-TIME SETUP: Run backend/supabase_setup.sql in your Supabase SQL Editor
# (Dashboard → Database → SQL Editor) to enable pgvector and add the
# embedding column to document_chunks.
# ────────────────────────────────────────────────────────────────────────────

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# App
APP_VERSION=1.0.0
