# ============================================================
# KnowledgeForge — Deployment Configuration
#
# HOW TO USE:
#   cp scripts/deploy.env.template deploy.env
#   nano deploy.env          # fill in your values
#   source deploy.env && ./scripts/deploy-aws.sh
#
# This file is gitignored — never commit deploy.env
# ============================================================

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
# ENV=prod   # change to 'dev' for a dev environment

# ── GitHub (repo that holds this code) ───────────────────────
GITHUB_ORG=euron-sudh
GITHUB_REPO=Enterprise-Grade-AI-Knowledge-Copilot

# ── AI API Keys (required) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Optional — leave blank to use mock mode
OPENAI_API_KEY=

# ── Database ──────────────────────────────────────────────────
# No @ or " characters allowed in password
DB_PASSWORD=KnowledgeForge2024Prod!

# ── Redis ─────────────────────────────────────────────────────
# Min 16 chars, no @ character
REDIS_AUTH_TOKEN=KFRedisToken2024Secure

# ── Secrets (leave blank to auto-generate) ────────────────────
JWT_SECRET=
APP_SECRET=

# ── Billing (optional — leave blank to skip) ──────────────────
STRIPE_SECRET_KEY=

# ── Alerts ────────────────────────────────────────────────────
NOTIFICATION_EMAIL=your@email.com

# ── Domain (optional — press Enter to skip SSL/DNS setup) ─────
DOMAIN=
